# ─── LearnHub — Environment Variables Example ────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# SQLite (local dev). Swap to postgresql://... for production.
DATABASE_URL="file:./prisma/dev.db"

# Auth — JWT signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-strong-random-secret-at-least-32-chars"
