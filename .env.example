# ─── LearnHub — Environment Variables Example ────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# PostgreSQL (Neon). Use the POOLED (-pooler) connection string for Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST/DBNAME?sslmode=require"

# Auth — JWT signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-strong-random-secret-at-least-32-chars"
